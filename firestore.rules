rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Global Safety Net: Default Deny
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isSignedIn() {
      return request.auth != null;
    }

    function isDev() {
      // Developer bypass for emergency fixes
      return isSignedIn() && request.auth.token.email == 't6068422@gmail.com';
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // ===============================================================
    // Shared Validation Blueprints
    // ===============================================================
    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             (!('currentStock' in data) || data.currentStock is number) &&
             (!('unit' in data) || data.unit is string) &&
             (!('category' in data) || data.category is string);
    }

    function isValidBuiltyItem(item) {
      return item.productId is string &&
             item.productName is string && item.productName.size() > 0 &&
             item.quantity is number && item.quantity >= 0 &&
             item.price is number && item.price >= 0;
    }

    function isValidBuilty(data) {
      return data.builtyNumber is string && data.builtyNumber.size() > 0 &&
             data.senderName is string &&
             data.receiverName is string &&
             data.destination is string &&
             data.date is timestamp &&
             (!('items' in data) || data.items is list);
    }

    // ===============================================================
    // Domain Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isDev() || (isSignedIn() && request.auth.uid == userId);
    }

    match /products/{productId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidProduct(incoming()) && isValidId(productId);
      allow update: if isSignedIn() && isValidProduct(incoming());
      allow delete: if isSignedIn();
    }

    match /production/{productionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(productionId);
      allow delete: if isSignedIn();
    }

    match /sales/{saleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(saleId);
      allow delete: if isSignedIn();
    }

    match /settings/{settingId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /clients/{clientId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(clientId);
    }

    match /builties/{builtyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidBuilty(incoming()) && isValidId(builtyId);
      allow update: if isSignedIn() && isValidBuilty(incoming());
      allow delete: if isSignedIn();
    }

    match /stockControlHistory/{historyId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && isValidId(historyId);
    }

    match /monthlyReports/{reportId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
      
      match /productStats/{productId} {
        allow read: if isSignedIn();
        allow write: if isSignedIn();
      }
    }
    
    match /test/connection {
      allow read: if true;
    }
  }
}
