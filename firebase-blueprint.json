{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] }
      },
      "required": ["uid", "email", "name", "role"]
    },
    "Product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "unit": { "type": "string" },
        "minStockLevel": { "type": "number" },
        "currentStock": { "type": "number" },
        "availableStock": { "type": "number" },
        "customFields": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "category", "unit", "minStockLevel", "currentStock", "availableStock"]
    },
    "Client": {
      "title": "Client",
      "description": "Client information for reporting",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "creditBalance": { "type": "number" },
        "totalSpent": { "type": "number" },
        "totalQuantity": { "type": "number" },
        "lastPurchaseDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "phone", "createdAt"]
    },
    "AppSetting": {
      "title": "AppSetting",
      "description": "Global application settings",
      "type": "object",
      "properties": {
        "customColumns": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Production": {
      "title": "Production",
      "description": "Daily production entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "addedBy": { "type": "string" }
      },
      "required": ["productId", "quantity", "date", "addedBy"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sales entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "quantity": { "type": "number" },
        "price": { "type": "number" },
        "total": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "soldBy": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" }
      },
      "required": ["productId", "quantity", "price", "total", "date", "soldBy"]
    },
    "StockControlHistory": {
      "title": "StockControlHistory",
      "description": "Snapshot of stock control entries",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "savedBy": { "type": "string" },
        "savedByName": { "type": "string" },
        "entries": { 
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "production": { "type": "number" },
              "qtySold": { "type": "number" },
              "price": { "type": "number" },
              "preparedStock": { "type": "number" },
              "customFields": { "type": "object" }
            }
          }
        },
        "customColumns": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["date", "savedBy", "savedByName", "entries"]
    },
    "MonthlyReport": {
      "title": "MonthlyReport",
      "description": "Aggregated monthly statistics",
      "type": "object",
      "properties": {
        "month": { "type": "string" },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "totalRevenue": { "type": "number" },
        "totalProduction": { "type": "number" },
        "totalSalesQty": { "type": "number" },
        "saveCount": { "type": "number" }
      },
      "required": ["month", "lastUpdated", "totalRevenue", "totalProduction", "totalSalesQty"]
    },
    "MonthlyProductStats": {
      "title": "MonthlyProductStats",
      "description": "Per-product aggregated monthly statistics",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "production": { "type": "number" },
        "qtySold": { "type": "number" },
        "revenue": { "type": "number" },
        "preparedStock": { "type": "number" },
        "currentStock": { "type": "number" },
        "price": { "type": "number" }
      },
      "required": ["productId", "productName", "production", "qtySold", "revenue"]
    },
    "Builty": {
      "title": "Builty",
      "description": "Consignment note or shipping document",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "builtyNumber": { "type": "string" },
        "senderName": { "type": "string" },
        "receiverName": { "type": "string" },
        "destination": { "type": "string" },
        "transportName": { "type": "string" },
        "totalItems": { "type": "number" },
        "weight": { "type": "string" },
        "freightAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "in-transit", "delivered", "cancelled"] },
        "date": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "productName": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" }
            },
            "required": ["productId", "productName", "quantity", "price"]
          }
        }
      },
      "required": ["builtyNumber", "senderName", "receiverName", "destination", "date", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Product inventory"
    },
    "/settings/{settingId}": {
      "schema": "AppSetting",
      "description": "App configuration"
    },
    "/clients/{clientId}": {
      "schema": "Client",
      "description": "Client database"
    },
    "/builties/{builtyId}": {
      "schema": "Builty",
      "description": "Logistics and shipping records"
    },
    "/production/{productionId}": {
      "schema": "Production",
      "description": "Production logs"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales logs"
    },
    "/stockControlHistory/{historyId}": {
      "schema": "StockControlHistory",
      "description": "Historical stock control records"
    },
    "/monthlyReports/{reportId}": {
      "schema": "MonthlyReport",
      "description": "Monthly performance summaries"
    },
    "/monthlyReports/{reportId}/productStats/{productId}": {
      "schema": "MonthlyProductStats",
      "description": "Detailed per-product monthly performance"
    }
  }
}
